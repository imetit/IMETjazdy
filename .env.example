# TatraSoft Orbit — environment template
# Copy to .env.local and fill in real values. NEVER commit .env.local.

# ─── Branding (white-label) ──────────────────────────────────────────
# Defaults below = verejná SaaS verzia. On-prem klienti (napr. IMET) môžu
# tieto premennej override-núť na svoj brand v ich .env.
NEXT_PUBLIC_BRAND_NAME="TatraSoft Orbit"
NEXT_PUBLIC_BRAND_SHORT_NAME="Orbit"
NEXT_PUBLIC_BRAND_TAGLINE="HR a vozový park v jednom systéme"
NEXT_PUBLIC_BRAND_VENDOR="TatraSoft s.r.o."
NEXT_PUBLIC_BRAND_SUPPORT_EMAIL="hello@tatrasoft.sk"
NEXT_PUBLIC_BRAND_LOGO_SRC="/imet-logo.png"
NEXT_PUBLIC_BRAND_DOMAIN="tatrasoft-orbit.vercel.app"
# Príklad pre IMET on-prem:
# NEXT_PUBLIC_BRAND_NAME="Imet Systems"
# NEXT_PUBLIC_BRAND_VENDOR="IMET, a.s."
# NEXT_PUBLIC_BRAND_SUPPORT_EMAIL="kontakt@imet.sk"

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=ey...
SUPABASE_SERVICE_ROLE_KEY=ey...     # SECRET — never expose to client

# Vercel cron (Authorization: Bearer ${CRON_SECRET})
CRON_SECRET=generate-strong-random-string

# Email (Resend)
RESEND_API_KEY=re_...

# Admin IP whitelist (comma-separated IPs/CIDRs). Empty = no whitelist.
ADMIN_IP_WHITELIST=

# Optional: utility scripts (bench, e2e)
SCRIPT_TEST_EMAIL=test@example.com
SCRIPT_TEST_PASSWORD=use-strong-password
BENCH_APP_URL=https://imetjazdy-work.vercel.app

# Phase 3+: Rate limit (Upstash)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Phase 6: Sentry
# SENTRY_DSN=
# SENTRY_AUTH_TOKEN=
